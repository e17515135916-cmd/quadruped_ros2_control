<?xml version="1.0"?>
<!--
  Dog2 Robot Description (Xacro Source)
  
  Recreated from correct URDF file
  Date: 2026-01-27
  
  INERTIA CORRECTIONS:
  - Leg 1 & 2: Positive X (front legs)
  - Leg 3 & 4: Negative X (rear legs, mirrored geometry)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dog2">

  <xacro:arg name="controllers_yaml" default="$(find dog2_description)/config/ros2_controllers.yaml"/>
  <xacro:property name="controllers_yaml" value="$(arg controllers_yaml)"/>

  <!-- Joint limits -->
  <xacro:property name="hip_lower_limit" value="-2.618"/>
  <xacro:property name="hip_upper_limit" value="2.618"/>
  <xacro:property name="hip_effort" value="50"/>
  <xacro:property name="hip_velocity" value="20"/>
  <xacro:property name="knee_lower_limit" value="-2.8"/>
  <xacro:property name="knee_upper_limit" value="2.8"/>
  <xacro:property name="knee_effort" value="50"/>
  <xacro:property name="knee_velocity" value="20"/>
  <xacro:property name="prismatic_effort" value="100"/>
  <xacro:property name="prismatic_velocity" value="5"/>

  <!-- Inertia properties -->
  <xacro:property name="leg12_thigh_xyz" value="0.026 -0.0760041259902766 0.0649874821212071"/>
  <xacro:property name="leg12_shin_xyz" value="0.0254901816398352 -0.143524743603395 -0.0694046953395906"/>
  <xacro:property name="leg3_thigh_xyz" value="-0.0259999999999999 -0.0760041259902766 0.0649874821212069"/>
  <xacro:property name="leg3_shin_xyz" value="-0.0265098183601649 -0.143524743603395 -0.0694046953395908"/>
  <xacro:property name="leg4_thigh_xyz" value="-0.026 -0.0760041259902766 0.0649874821212069"/>
  <xacro:property name="leg4_shin_xyz" value="-0.0265089672547710 -0.1429895138560395 -0.0691152554666486"/>

  <!-- World and base -->
  <link name="world"/>
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="1.2272 -0.7470 0.2649" rpy="1.5708 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.0153" ixy="0.00011" ixz="0" iyy="0.052" iyz="0" izz="0.044"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <xacro:property name="l1_inertia_xyz" value="-0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l2_inertia_xyz" value="0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l3_inertia_xyz" value="-0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l4_inertia_xyz" value="0.0159999123716776 0.000737036465389251 0.0261570925915838"/>

  <!-- Leg macro -->
  <xacro:macro name="leg" params="prefix leg_num xyz rpy p_low p_up thigh_xyz shin_xyz slider_inertia_xyz
                                 hip_rpy:='0 0 1.5708' hip_xyz:='-0.016 0.0199 0.055'
                                 knee_xyz:='-0.0233 -0.055 0.0274'
                                 thigh_rpy:='0 0 0' thigh_col_rpy:='0 0 0'">

  <link name="l${leg_num}">
    <inertial>
      <origin rpy="0 0 0" xyz="${slider_inertia_xyz}"/>
      <mass value="0.3"/>
      <inertia ixx="0.000107100908138004" ixy="0" ixz="0" iyy="8.38648309010005E-05" iyz="0" izz="7.86994452918461E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="j${leg_num}" type="prismatic">
    <origin rpy="${rpy}" xyz="${xyz}"/>
    <parent link="base_link"/>
    <child link="l${leg_num}"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${prismatic_effort}" lower="${p_low}" upper="${p_up}" velocity="${prismatic_velocity}"/>
  </joint>

  <link name="${prefix}_hip_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0233000000000003 -0.038305456702832 0.000879463367713051"/>
      <mass value="0.25"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}1.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.266666666666667 0.529411764705882 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}1.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_haa_joint" type="revolute">
    <origin rpy="${hip_rpy}" xyz="${hip_xyz}"/>
    <parent link="l${leg_num}"/>
    <child link="${prefix}_hip_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${hip_effort}" lower="${hip_lower_limit}" upper="${hip_upper_limit}" velocity="${hip_velocity}"/>
  </joint>

  <link name="${prefix}_upper_leg_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${thigh_xyz}"/>
      <mass value="0.4"/>
      <inertia ixx="0.000666" ixy="0" ixz="0" iyy="0.000356" iyz="0.000266" izz="0.000534"/>
    </inertial>
    <visual>
      <origin rpy="${thigh_rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}11.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="${thigh_col_rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}11.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_hfe_joint" type="revolute">
    <origin rpy="1.5708 1.5708 0" xyz="${knee_xyz}"/>
    <parent link="${prefix}_hip_link"/>
    <child link="${prefix}_upper_leg_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${knee_effort}" lower="${knee_lower_limit}" upper="${knee_upper_limit}" velocity="${knee_velocity}"/>
  </joint>

  <link name="${prefix}_lower_leg_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${shin_xyz}"/>
      <mass value="0.5"/>
      <inertia ixx="0.004517" ixy="0.00000870" ixz="0.00000420" iyy="0.000975" iyz="-0.00176971" izz="0.003666"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}111.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}111.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_kfe_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 -0.15201 0.12997"/>
    <parent link="${prefix}_upper_leg_link"/>
    <child link="${prefix}_lower_leg_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${knee_effort}" lower="${knee_lower_limit}" upper="${knee_upper_limit}" velocity="${knee_velocity}"/>
  </joint>

  <gazebo reference="${prefix}_lower_leg_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>

  </xacro:macro>

  <!-- Leg instantiations -->
  <!-- Leg 1: Front Left (lf) -->
  <xacro:leg prefix="lf" leg_num="1" xyz="1.1026 -0.80953 0.2649" rpy="1.5708 0 0" p_low="-0.111" p_up="0.0"
             thigh_xyz="${leg12_thigh_xyz}" shin_xyz="${leg12_shin_xyz}" slider_inertia_xyz="${l1_inertia_xyz}"/>

  <!-- Leg 2: Front Right (rf) -->
  <xacro:leg prefix="rf" leg_num="2" xyz="1.3491 -0.80953 0.2649" rpy="1.5708 0 0" p_low="0.0" p_up="0.111"
             thigh_xyz="${leg12_thigh_xyz}" shin_xyz="${leg12_shin_xyz}" slider_inertia_xyz="${l2_inertia_xyz}"
             hip_xyz="0.016 0.0199 0.055"/>

  <!-- Leg 3: Rear Left (lh) -->
  <xacro:leg prefix="lh" leg_num="3" xyz="1.3491 -0.68953 0.2649" rpy="1.5708 0 -3.1416" p_low="-0.111" p_up="0.0"
             thigh_xyz="${leg3_thigh_xyz}" shin_xyz="${leg3_shin_xyz}" slider_inertia_xyz="${l3_inertia_xyz}"
             hip_rpy="3.1416 0 1.5708" knee_xyz="-0.0233 -0.055 -0.0254"/>

  <!-- Leg 4: Rear Right (rh) -->
  <xacro:leg prefix="rh" leg_num="4" xyz="1.1071 -0.68953 0.2649" rpy="1.5708 0 -3.1416" p_low="0.0" p_up="0.111"
             thigh_xyz="${leg4_thigh_xyz}" shin_xyz="${leg4_shin_xyz}" slider_inertia_xyz="${l4_inertia_xyz}"
             hip_rpy="3.1416 0 1.5708" hip_xyz="0.0116 0.0199 0.055" knee_xyz="-0.0233 -0.055 -0.0254"
             thigh_rpy="0 3.1416 0" thigh_col_rpy="0 3.1416 0"/>

  <!-- ROS 2 Control -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="j1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_haa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_hfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_kfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_haa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_hfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_kfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_haa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_hfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_kfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_haa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_hfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_kfe_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>${controllers_yaml}</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>

</robot>
