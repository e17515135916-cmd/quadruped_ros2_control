<?xml version="1.0"?>
<!--
  Dog2 Robot Description (Xacro Source)
  
  Recreated from correct URDF file
  Date: 2026-01-27
  
  INERTIA CORRECTIONS:
  - Leg 1 & 2: Positive X (front legs)
  - Leg 3 & 4: Negative X (rear legs, mirrored geometry)
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dog2">

  <xacro:arg name="controllers_yaml" default="$(find dog2_description)/config/ros2_controllers.yaml"/>
  <xacro:property name="controllers_yaml" value="$(arg controllers_yaml)"/>

  <!-- Joint limits -->
  <xacro:property name="hip_lower_limit" value="-2.618"/>
  <xacro:property name="hip_upper_limit" value="2.618"/>
  <xacro:property name="hip_effort" value="50"/>
  <xacro:property name="hip_velocity" value="20"/>
  <xacro:property name="knee_lower_limit" value="-2.8"/>
  <xacro:property name="knee_upper_limit" value="2.8"/>
  <xacro:property name="knee_effort" value="50"/>
  <xacro:property name="knee_velocity" value="20"/>
  <xacro:property name="prismatic_effort" value="100"/>
  <xacro:property name="prismatic_velocity" value="5"/>

  <!-- Shared angle constants -->
  <xacro:property name="PI_CONST" value="3.141592653589793"/>
  <xacro:property name="half_pi" value="1.5707963267948966"/>

  <!-- Joint passive dynamics (simulation stabilization) -->
  <xacro:property name="prismatic_damping" value="0.25"/>
  <xacro:property name="prismatic_friction" value="0.05"/>
  <xacro:property name="hip_damping" value="0.12"/>
  <xacro:property name="hip_friction" value="0.02"/>
  <xacro:property name="knee_damping" value="0.15"/>
  <xacro:property name="knee_friction" value="0.02"/>

  <!-- Contact model (conservative baseline for stability) -->
  <xacro:property name="foot_contact_mu1" value="1.0"/>
  <xacro:property name="foot_contact_mu2" value="1.0"/>
  <xacro:property name="foot_contact_kp" value="2.0e4"/>
  <xacro:property name="foot_contact_kd" value="20.0"/>
  <xacro:property name="foot_contact_min_depth" value="0.0005"/>
  <xacro:property name="foot_contact_max_vel" value="0.2"/>

  <!-- Inertia properties -->
  <xacro:property name="leg12_thigh_xyz" value="0.026 -0.0760041259902766 0.0649874821212071"/>
  <xacro:property name="leg12_shin_xyz" value="0.0254901816398352 -0.143524743603395 -0.0694046953395906"/>
  <xacro:property name="leg3_thigh_xyz" value="-0.0259999999999999 -0.0760041259902766 0.0649874821212069"/>
  <xacro:property name="leg3_shin_xyz" value="-0.0265098183601649 -0.143524743603395 -0.0694046953395908"/>
  <xacro:property name="leg4_thigh_xyz" value="-0.026 -0.0760041259902766 0.0649874821212069"/>
  <xacro:property name="leg4_shin_xyz" value="-0.0265089672547710 -0.1429895138560395 -0.0691152554666486"/>

  <!-- World and base -->
  <link name="base_footprint"/>

  <!--
    CAD-origin compensation (global URDF shift)
    ============================================================
    WHY:
      Source CAD/mesh was exported with a large global offset.

    UNIQUE COMPENSATION LAYER (ENFORCED):
      * urdf_shift is used ONLY in base_offset_joint.
      * All other origins below are expressed directly in base_link-local
        coordinates after compensation.

    STRICT BOUNDARY:
      * DO NOT apply this shift again in TF publishers, sensor extrinsics,
        MPC/WBC kinematics, Python config, or controller code.
      * Any second compensation will cause frame mismatch (double offset).

    MAINTENANCE RULE:
      If CAD is re-exported with corrected origin, update urdf_shift and
      re-baseline base_link-local constants with validation script.
  -->
  <xacro:property name="urdf_shift_x" value="0.9780"/>
  <xacro:property name="urdf_shift_y" value="-0.87203"/>
  <xacro:property name="urdf_shift_z" value="0.2649"/>

  <joint name="base_offset_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="${1.2272 - urdf_shift_x} ${-0.7470 - urdf_shift_y} ${0.0 - urdf_shift_z}" rpy="0 0 ${PI_CONST}"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.2492 0.12503 0.0" rpy="${half_pi} 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.0153" ixy="0.00011" ixz="0" iyy="0.052" iyz="0" izz="0.044"/>
    </inertial>
    <visual>
      <origin xyz="-0.9780 0.87203 -0.2649" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/base_link.STL"/>
      </geometry>
      <material name="mat_base_gray">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.9780 0.87203 -0.2649" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <xacro:property name="l1_inertia_xyz" value="-0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l2_inertia_xyz" value="0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l3_inertia_xyz" value="-0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l4_inertia_xyz" value="0.0159999123716776 0.000737036465389251 0.0261570925915838"/>

  <!-- Leg macro -->
  <xacro:macro name="leg" params="prefix leg_num xyz_x xyz_y xyz_z rpy p_low p_up thigh_xyz shin_xyz slider_inertia_xyz
                                 hip_rpy:='0 0 ${half_pi}' hip_xyz:='-0.016 0.0199 0.055'
                                 knee_xyz:='-0.0233 -0.055 0.0274'
                                 thigh_rpy:='0 0 0' thigh_col_rpy:='0 0 0'">

  <link name="${prefix}_rail_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${slider_inertia_xyz}"/>
      <mass value="0.3"/>
      <inertia ixx="0.0001071" ixy="0" ixz="0" iyy="8.386e-05" iyz="0" izz="7.869e-05"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}.STL"/>
      </geometry>
      <material name="mat_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_rail_joint" type="prismatic">
    <origin rpy="${rpy}" xyz="${xyz_x} ${xyz_y} ${xyz_z}"/>
    <parent link="base_link"/>
    <child link="${prefix}_rail_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${prismatic_effort}" lower="${p_low}" upper="${p_up}" velocity="${prismatic_velocity}"/>
    <dynamics damping="${prismatic_damping}" friction="${prismatic_friction}"/>
  </joint>

  <link name="${prefix}_coxa_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0233 -0.0383 0.000879"/>
      <mass value="0.25"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}1.STL"/>
      </geometry>
      <material name="mat_blue"><color rgba="0.266 0.529 1 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}1_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_coxa_joint" type="revolute">
    <origin rpy="${hip_rpy}" xyz="${hip_xyz}"/>
    <parent link="${prefix}_rail_link"/>
    <child link="${prefix}_coxa_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${hip_effort}" lower="${hip_lower_limit}" upper="${hip_upper_limit}" velocity="${hip_velocity}"/>
    <dynamics damping="${hip_damping}" friction="${hip_friction}"/>
  </joint>

  <link name="${prefix}_femur_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${thigh_xyz}"/>
      <mass value="0.4"/>
      <inertia ixx="0.000666" ixy="0" ixz="0" iyy="0.000356" iyz="0.000266" izz="0.000534"/>
    </inertial>
    <visual>
      <origin rpy="${thigh_rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}11.STL"/>
      </geometry>
      <material name="mat_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin rpy="${thigh_col_rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}11_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_femur_joint" type="revolute">
    <origin rpy="${half_pi} ${half_pi} 0" xyz="${knee_xyz}"/>
    <parent link="${prefix}_coxa_link"/>
    <child link="${prefix}_femur_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${knee_effort}" lower="${knee_lower_limit}" upper="${knee_upper_limit}" velocity="${knee_velocity}"/>
    <dynamics damping="${knee_damping}" friction="${knee_friction}"/>
  </joint>

  <link name="${prefix}_tibia_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${shin_xyz}"/>
      <mass value="0.5"/>
      <inertia ixx="0.004517" ixy="0.0000087" ixz="0.0000042" iyy="0.000975" iyz="-0.001769" izz="0.003666"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}111.STL"/>
      </geometry>
      <material name="mat_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}111_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_tibia_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 -0.15201 0.12997"/>
    <parent link="${prefix}_femur_link"/>
    <child link="${prefix}_tibia_link"/>
    <axis xyz="-1 0 0"/>
    <limit effort="${knee_effort}" lower="${knee_lower_limit}" upper="${knee_upper_limit}" velocity="${knee_velocity}"/>
    <dynamics damping="${knee_damping}" friction="${knee_friction}"/>
  </joint>

  <!--
    Contact is currently attached to tibia as foot proxy.
    TODO: split dedicated foot link/contact surface when available.
  -->
  <gazebo reference="${prefix}_tibia_link">
    <mu1>${foot_contact_mu1}</mu1>
    <mu2>${foot_contact_mu2}</mu2>
    <kp>${foot_contact_kp}</kp>
    <kd>${foot_contact_kd}</kd>
    <minDepth>${foot_contact_min_depth}</minDepth>
    <maxVel>${foot_contact_max_vel}</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>

  </xacro:macro>

  <!-- Leg instantiations -->
  <!--
    Leg topology reminder (base_link-local):
      - lf: left front  (左前)
      - lh: left rear   (左后)
      - rh: right rear  (右后)
      - rf: right front (右前)
  -->
  <!-- Leg 1: Front Left (lf) base_link-local anchor -->
  <xacro:leg prefix="lf" leg_num="1" xyz_x="0.1246" xyz_y="0.0625" xyz_z="0.0" rpy="${half_pi} 0 0" p_low="-0.111" p_up="0.0"
             thigh_xyz="${leg12_thigh_xyz}" shin_xyz="${leg12_shin_xyz}" slider_inertia_xyz="${l1_inertia_xyz}"/>

  <!-- Leg 2: Rear Left (lh) base_link-local anchor -->
  <xacro:leg prefix="lh" leg_num="2" xyz_x="0.3711" xyz_y="0.0625" xyz_z="0.0" rpy="${half_pi} 0 0" p_low="0.0" p_up="0.111"
             thigh_xyz="${leg12_thigh_xyz}" shin_xyz="${leg12_shin_xyz}" slider_inertia_xyz="${l2_inertia_xyz}"
             hip_xyz="0.016 0.0199 0.055"/>

  <!-- Leg 3: Rear Right (rh) base_link-local anchor -->
  <xacro:leg prefix="rh" leg_num="3" xyz_x="0.3711" xyz_y="0.1825" xyz_z="0.0" rpy="${half_pi} 0 ${-pi}" p_low="-0.111" p_up="0.0"
             thigh_xyz="${leg3_thigh_xyz}" shin_xyz="${leg3_shin_xyz}" slider_inertia_xyz="${l3_inertia_xyz}"
             hip_rpy="${pi} 0 ${half_pi}" knee_xyz="-0.0233 -0.055 -0.0254"/>

  <!-- Leg 4: Front Right (rf) base_link-local anchor -->
  <xacro:leg prefix="rf" leg_num="4" xyz_x="0.1291" xyz_y="0.1825" xyz_z="0.0" rpy="${half_pi} 0 ${-pi}" p_low="0.0" p_up="0.111"
             thigh_xyz="${leg4_thigh_xyz}" shin_xyz="${leg4_shin_xyz}" slider_inertia_xyz="${l4_inertia_xyz}"
             hip_rpy="${pi} 0 ${half_pi}" hip_xyz="0.0116 0.0199 0.055" knee_xyz="-0.0233 -0.055 -0.0254"
             thigh_rpy="0 ${pi} 0" thigh_col_rpy="0 ${pi} 0"/>

  <!-- ROS 2 Control -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="lf_rail_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_coxa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_femur_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_tibia_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_rail_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_coxa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_femur_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_tibia_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_rail_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_coxa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_femur_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_tibia_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_rail_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_coxa_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_femur_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_tibia_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>${controllers_yaml}</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>

</robot>
