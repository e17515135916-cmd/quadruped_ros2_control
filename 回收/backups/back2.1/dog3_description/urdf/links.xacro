<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <link name="l1">
        <inertial>
            <origin xyz="-0.0159999123716776 0.000737036465389251 0.0261570925915838" rpy="0 0 0" />
            <mass value="0.512324909923602" />
            <inertia
                ixx="0.000107100908138004"
                ixy="-2.20668777896138E-10"
                ixz="4.49732110866214E-10"
                iyy="8.38648309010005E-05"
                iyz="2.6880003941817E-06"
                izz="7.86994452918461E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://dog2_description/meshes/l1.STL" />
            </geometry>
            <material name="white">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://dog2_description/meshes/l1.STL" />
            </geometry>
        </collision>
    </link>

    <joint name="j1" type="prismatic">
        <origin xyz="1.1026 -0.80953 0.2649" rpy="1.5708 0 0" />
        <parent link="base_link" />
        <child link="l1" />
        <axis xyz="-1 0 0" />
        <limit lower="-0.5" upper="0.5" effort="100" velocity="1" />
    </joint>

    <transmission name="j1_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="j1">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="j1_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <link name="l11">
        <inertial>
            <origin xyz="-0.0233000000000003 -0.038305456702832 0.000879463367713051" rpy="0 0 0" />
            <mass value="0.346974608756836" />
            <inertia
                ixx="8.66399512887475E-05"
                ixy="3.24725100956478E-20"
                ixz="3.85561445682508E-20"
                iyy="7.91945845868074E-05"
                iyz="-5.18707927463093E-20"
                izz="7.11734259202265E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://dog2_description/meshes/l11.STL" />
            </geometry>
            <material name="blue">
                <color rgba="0.266666666666667 0.529411764705882 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://dog2_description/meshes/l11.STL" />
            </geometry>
        </collision>
    </link>

    <joint name="j11" type="continuous">
        <origin xyz="-0.016 0.0199 0.055" rpy="0 0 1.5708" />
        <parent link="l1" />
        <child link="l11" />
        <axis xyz="-1 0 0" />
    </joint>

    <transmission name="j11_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="j11">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="j11_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <link name="l111">
        <inertial>
            <origin xyz="0.026 -0.0760041259902766 0.0649874821212071" rpy="0 0 0" />
            <mass value="0.675776067601477" />
            <inertia
                ixx="0.00243508708358432"
                ixy="1.19576912393884E-18"
                ixz="8.27103206755517E-19"
                iyy="0.00150990083615139"
                iyz="0.00115453599507958"
                izz="0.00187296482245536" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://dog2_description/meshes/l111.STL" />
            </geometry>
            <material name="white">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://dog2_description/meshes/l111.STL" />
            </geometry>
        </collision>
    </link>

    <joint name="j111" type="continuous">
        <origin xyz="0.026 -0.0761 0.065" rpy="0 0 0" />
        <parent link="l11" />
        <child link="l111" />
        <axis xyz="0 1 0" />
    </joint>

    <transmission name="j111_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="j111">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="j111_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <!-- Gazebo colors -->
    <gazebo reference="l1">
        <material>Gazebo/White</material>
    </gazebo>

    <gazebo reference="l11">
        <material>Gazebo/Blue</material>
    </gazebo>

    <gazebo reference="l111">
        <material>Gazebo/White</material>
    </gazebo>

    <!-- Gazebo joint control plugins -->
    <gazebo>
        <plugin name="joint_state_publisher" filename="libgazebo_ros2_joint_state_publisher.so">
            <update_rate>50</update_rate>
            <joint_name>j1</joint_name>
            <joint_name>j11</joint_name>
            <joint_name>j111</joint_name>
        </plugin>
    </gazebo>

</robot>