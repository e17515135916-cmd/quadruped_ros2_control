      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l41.STL"/>
      </geometry>
    </collision>
  </link>
  <!-- Hip joint (j${leg_num}1) -->
  <joint name="j41" type="revolute">
    <origin rpy="3.1416 0 1.5708" xyz="0.0116 0.0199 0.055"/>
    <parent link="l4"/>
    <child link="l41"/>
    <axis xyz="-1 0 0"/>
    <limit effort="50" lower="-2.618" upper="2.618" velocity="20"/>
  </joint>
  <!-- Thigh link (l${leg_num}11) -->
  <link name="l411">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.026 -0.0760041259902766 0.0649874821212069"/>
      <mass value="0.4"/>
      <inertia ixx="0.000666" ixy="0" ixz="0" iyy="0.000356" iyz="0.000266" izz="0.000534"/>
    </inertial>
    <visual>
      <origin rpy="0 3.1416 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l411.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 3.1416 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l411.STL"/>
      </geometry>
    </collision>
  </link>
  <!-- Hip flexion/extension joint (HFE) (j${leg_num}11) -->
  <joint name="j411" type="revolute">
    <origin rpy="1.5708 1.5708 0" xyz="-0.0233 -0.055 -0.0254"/>
    <parent link="l41"/>
    <child link="l411"/>
    <axis xyz="-1 0 0"/>
    <limit effort="50" lower="-2.8" upper="2.8" velocity="20"/>
  </joint>
  <!-- Shin link (l${leg_num}111) -->
  <link name="l4111">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0265089672547710 -0.1429895138560395 -0.0691152554666486"/>
      <mass value="0.5"/>
      <inertia ixx="0.004517" ixy="0.00000870" ixz="0.00000420" iyy="0.000975" iyz="-0.00176971" izz="0.003666"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l4111.STL"/>
      </geometry>
      <material name="">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l4111.STL"/>
      </geometry>
    </collision>
  </link>
  <!-- Knee joint (KFE) (j${leg_num}111) -->
  <joint name="j4111" type="revolute">
    <origin rpy="0 0 0" xyz="0 -0.15201 0.12997"/>
    <parent link="l411"/>
    <child link="l4111"/>
    <axis xyz="-1 0 0"/>
    <limit effort="50" lower="-2.8" upper="0.0" velocity="20"/>
  </joint>
  <!-- Gazebo friction configuration for shin link -->
  <gazebo reference="l4111">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>
  <!-- Foot link (l${leg_num}1111) - Spherical geometry -->
  <link name="l41111">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="8e-6" ixy="0" ixz="0" iyy="8e-6" iyz="0" izz="8e-6"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
  </link>
  <!-- Fixed joint connecting shin to foot (j${leg_num}1111) -->
  <joint name="j41111" type="fixed">
    <origin rpy="0 0 0" xyz="0 -0.22 0"/>
    <parent link="l4111"/>
    <child link="l41111"/>
  </joint>
  <!-- Gazebo friction configuration for foot link -->
  <gazebo reference="l41111">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/Grey</material>
  </gazebo>
  <!-- ============================================ -->
  <!-- SECTION 4: ROS 2 CONTROL & GAZEBO            -->
  <!-- ============================================ -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <!-- Leg 1 Joints -->
    <joint name="j1">
      <command_interface name="effort"/>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j11">
      <command_interface name="effort"/>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j111">
      <command_interface name="effort"/>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- Leg 2 Joints -->
    <joint name="j2">
      <command_interface name="effort"/>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j21">
      <command_interface name="effort"/>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j211">
