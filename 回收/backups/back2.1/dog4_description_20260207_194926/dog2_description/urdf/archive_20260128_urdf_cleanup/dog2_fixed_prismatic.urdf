    <actuator name="j211_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j2111_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j2111">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j2111_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j3_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j3">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j3_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j31_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j31">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j31_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j311_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j311">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j311_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j3111_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j3111">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j3111_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j4_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j4">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j4_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j41_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j41">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j41_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j411_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j411">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j411_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="j4111_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="j4111">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="j4111_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
    </plugin>
  </gazebo>
  
  <!-- IMU Sensor on base_link -->
  <gazebo reference="base_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>__default_topic__</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>base_link</frame_name>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>
  
  <!-- ROS2 Control Configuration -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    
    <!-- Right Hind Leg (j1, j11, j111, j1111) -->
    <joint name="j1">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j11">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j111">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j1111">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Right Front Leg (j2, j21, j211, j2111) -->
    <joint name="j2">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j21">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j211">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j2111">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Left Front Leg (j3, j31, j311, j3111) -->
    <joint name="j3">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j31">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j311">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j3111">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Left Hind Leg (j4, j41, j411, j4111) -->
    <joint name="j4">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j41">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j411">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="j4111">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>{ROS_CONTROL_CONFIG_PATH}</parameters>
    </plugin>
  </gazebo>
  <link name="l1111_ft_sensor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1E-06" ixy="0" ixz="0" iyy="1E-06" iyz="0" izz="1E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.03" />
      </geometry>
      <material name="sensor_green">
        <color rgba="0 1 0 1" />
      </material>
    </visual>
  </link>
  <joint name="l1111_ft_joint" type="fixed">
    <origin xyz="0 0 -0.03" rpy="0 0 0" />
    <parent link="l1111" />
    <child link="l1111_ft_sensor" />
  </joint>
  <gazebo reference="l1111_ft_sensor">
    <sensor name="right_hind_ft_sensor" type="force_torque">
      <update_rate>500</update_rate>
      <force_torque>
        <frame>child</frame>
        <measure_direction>child_to_parent</measure_direction>
      </force_torque>
      <plugin name="gazebo_ros_ft_sensor_right_hind" filename="libgazebo_ros_ft_sensor.so">
        <ros>
          <namespace>/dog2/right_hind</namespace>
          <remapping>~/out:=ft_sensor_data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Contact sensor for right hind foot -->
  <gazebo reference="l1111">
    <sensor name="l1111_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>l1111_fixed_joint_lump__l1111_collision_collision</collision>
      </contact>
    </sensor>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <link name="l2111_ft_sensor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1E-06" ixy="0" ixz="0" iyy="1E-06" iyz="0" izz="1E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.03" />
      </geometry>
      <material name="sensor_green">
        <color rgba="0 1 0 1" />
      </material>
    </visual>
  </link>
  <joint name="l2111_ft_joint" type="fixed">
    <origin xyz="0 0 -0.03" rpy="0 0 0" />
    <parent link="l2111" />
    <child link="l2111_ft_sensor" />
  </joint>
  <gazebo reference="l2111_ft_sensor">
    <sensor name="right_front_ft_sensor" type="force_torque">
      <update_rate>500</update_rate>
      <force_torque>
        <frame>child</frame>
        <measure_direction>child_to_parent</measure_direction>
      </force_torque>
      <plugin name="gazebo_ros_ft_sensor_right_front" filename="libgazebo_ros_ft_sensor.so">
        <ros>
          <namespace>/dog2/right_front</namespace>
          <remapping>~/out:=ft_sensor_data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Contact sensor for right front foot -->
  <gazebo reference="l2111">
    <sensor name="l2111_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>l2111_fixed_joint_lump__l2111_collision_collision</collision>
      </contact>
    </sensor>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <link name="l3111_ft_sensor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1E-06" ixy="0" ixz="0" iyy="1E-06" iyz="0" izz="1E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.03" />
      </geometry>
      <material name="sensor_green">
        <color rgba="0 1 0 1" />
      </material>
    </visual>
  </link>
  <joint name="l3111_ft_joint" type="fixed">
    <origin xyz="0 0 -0.03" rpy="0 0 0" />
    <parent link="l3111" />
    <child link="l3111_ft_sensor" />
  </joint>
  <gazebo reference="l3111_ft_sensor">
    <sensor name="left_front_ft_sensor" type="force_torque">
      <update_rate>500</update_rate>
      <force_torque>
        <frame>child</frame>
        <measure_direction>child_to_parent</measure_direction>
      </force_torque>
      <plugin name="gazebo_ros_ft_sensor_left_front" filename="libgazebo_ros_ft_sensor.so">
        <ros>
          <namespace>/dog2/left_front</namespace>
          <remapping>~/out:=ft_sensor_data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Contact sensor for left front foot -->
  <gazebo reference="l3111">
    <sensor name="l3111_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>l3111_fixed_joint_lump__l3111_collision_collision</collision>
      </contact>
    </sensor>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <link name="l4111_ft_sensor">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="1E-06" ixy="0" ixz="0" iyy="1E-06" iyz="0" izz="1E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.03" />
      </geometry>
      <material name="sensor_green">
        <color rgba="0 1 0 1" />
      </material>
    </visual>
  </link>
  <joint name="l4111_ft_joint" type="fixed">
    <origin xyz="0 0 -0.03" rpy="0 0 0" />
    <parent link="l4111" />
    <child link="l4111_ft_sensor" />
  </joint>
  <gazebo reference="l4111_ft_sensor">
    <sensor name="left_hind_ft_sensor" type="force_torque">
      <update_rate>500</update_rate>
      <force_torque>
        <frame>child</frame>
        <measure_direction>child_to_parent</measure_direction>
      </force_torque>
      <plugin name="gazebo_ros_ft_sensor_left_hind" filename="libgazebo_ros_ft_sensor.so">
        <ros>
          <namespace>/dog2/left_hind</namespace>
          <remapping>~/out:=ft_sensor_data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Contact sensor for left hind foot -->
  <gazebo reference="l4111">
    <sensor name="l4111_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>l4111_fixed_joint_lump__l4111_collision_collision</collision>
      </contact>
    </sensor>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
</robot>
