        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 3.1416 0" />
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="l411">
    <material>Gazebo/White</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
  </gazebo>

  <joint name="j411" type="revolute">
    <origin xyz="-0.0233 -0.055 -0.0254" rpy="1.5708 1.5708 0" />
    <parent link="l41" />
    <child link="l411" />
    <axis xyz="0 1 0" />
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
  <gazebo reference="j411">
    <implicitSpringDamper>1</implicitSpringDamper>
  </gazebo>

  <link name="l4111">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://panda_description/meshes/l4111.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision name="l4111_collision">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://panda_description/meshes/l4111.STL" />
      </geometry>
    </collision>
  </link>
  <gazebo reference="l4111">
    <sensor name="l4111_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>l4111_collision</collision>
      </contact>
    </sensor>
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
  </gazebo>

  <joint name="j4111" type="fixed">
    <origin xyz="0 -0.15201 0.12997" rpy="0 0 0" />
    <parent link="l411" />
    <child link="l4111" />
  </joint>
  <gazebo reference="j4111">
    <implicitSpringDamper>1</implicitSpringDamper>
  </gazebo>

  <!-- <gazebo>
    <plugin name="ground_truth" filename="libgazebo_ros_p3d.so">
      <ros>
        <remapping>odom:=/dog2/ground_truth</remapping>
